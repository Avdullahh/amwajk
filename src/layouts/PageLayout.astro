---
import Layout from '~/layouts/Layout.astro';
import Header from '~/components/widgets/Header.astro';
import Footer from '~/components/widgets/Footer.astro';

import { getHeaderData, getFooterData } from '~/navigation';
import type { Locale } from '~/i18n/ui';

import type { MetaData } from '~/types';

export interface Props {
  metadata?: MetaData;
  locale?: Locale;
}

const { metadata, locale = 'ar' } = Astro.props;
const isAr = locale === 'ar';
const headerData = getHeaderData(locale);
const footerData = getFooterData(locale);
---

<Layout metadata={metadata} language={isAr ? 'ar' : 'en'} textDirection={isAr ? 'rtl' : 'ltr'}>
  <slot name="header">
    <Header {...headerData} isSticky />
  </slot>
  <main>
    <slot />
  </main>
  <slot name="footer">
    <Footer {...footerData} />
  </slot>
</Layout>
